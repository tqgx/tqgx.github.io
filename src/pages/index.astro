---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tile from "../layouts/Tile.astro";
import MoreTile from "../layouts/MoreTile.astro";
const allPosts = await Astro.glob("../pages/posts/*.md");
allPosts.sort((a, b) => Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate));
---

<BaseLayout>
  <section class="everydayfeed">

              <div class="view-archive-wrapper">
      <h1 class="section-head">Latest News</h1>
    <div style="text-align: center; font-size: 117px; margin-top: -15px; height: 0px; overflow-x:auto ; white-space: nowrap;">
        <p="/" style="color: #D6D6D6;">Filter by tag:</a>&nbsp;&nbsp


      </div>
        <a href="/tags/SOFTWARE" class="cta-primary-light" data-analytics-region="router" data-analytics-title="view archive">SOFTWARE</a>
              <a href="/tags/⚡ QUICK READ" class="cta-primary-light" data-analytics-region="router" data-analytics-title="view archive">⚡ QUICK READ</a>
        <a href="/tags/TQGX" class="cta-primary-light" data-analytics-region="router" data-analytics-title="view archive">TQGX</a>

  <section class="everydayfeed">
      </ul><div class="section-content" style="width:1450px;">

        <ul role="list" class="section-tiles">
        {
          // tile-hero
          allPosts.slice(0, 12).map((post) => {
            return (
              <Tile title={post.frontmatter.title} href={post.url} date={post.frontmatter.pubDate} tags={post.frontmatter.tags} cover={post.frontmatter.cover.url} level="2" />
            );
          })
        }
      </ul><div class="section-content" style="width:1450px;">

  
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      var script = document.createElement("script");
      script.src = "/static/js/animation.js";
      document.head.appendChild(script);

      script.onload = function () {
        console.log("lazyload.js loaded");
        // when layout is loaded, load the images
        initImage();
      };
    });
  </script>
</BaseLayout>


  <section class="everydayfeed">
    <div class="section-content">




      </div>
                            <img src="https://github.com/tqgx/tqgx/blob/main/TQGX/AI3.png?raw=true" alt="Image of a cat" class="section-content">
                <img src="https://github.com/tqgx/tqgx/blob/main/TQGX/Gentoo1.png?raw=true" alt="Image of a cat" class="section-content">
                    <div class="view-archive-wrapper">
        <a href="posts/16" class="cta-primary-light" data-analytics-region="router" data-analytics-title="view archive">View All</a>
      </div>

                <h2 class="section-head">ㅤ</h2>
              <h2 class="section-head">More from TQGX</h2>
      <ul role="list" class="section-tiles">

        {
          // tile-2up
          allPosts.slice(12, 24).map((post) => {
            return (
              <MoreTile title={post.frontmatter.title} href={post.url} date={post.frontmatter.pubDate} tags={post.frontmatter.tags} cover={post.frontmatter.cover.url} />
            );
          })
        }

      </ul>
    </div>
  </section>

      <div class="view-archive-wrapper">
        <a href="/archive" class="cta-primary-light" data-analytics-region="router" data-analytics-title="view archive">View Archive</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      var script = document.createElement("script");
      script.src = "/static/js/animation.js";
      document.head.appendChild(script);

      script.onload = function () {
        console.log("lazyload.js loaded");
        // when layout is loaded, load the images
        initImage();
      };
    });
  </script>
